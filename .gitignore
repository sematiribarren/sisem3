# Este archivo le dice a Git qué archivos o carpetas NO debe rastrear.
# Creado para un proyecto Django estándar.

### Python ###
# Archivos compilados (bytecode) y cachés: generados automáticamente, no aportan nada.
__pycache__/
*.py[cod]
*$py.class

# Archivos de distribución / empaquetado
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
migrations/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Instaladores y logs
pip-log.txt
pip-delete-this-directory.txt
*.log

# Reportes de pruebas y cobertura
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

### Django ###
# Base de datos SQLite (si la usas localmente). ¡No subir a GitHub!
*.sqlite3
db.sqlite3
db.sqlite3-journal

# Archivos de configuración local y secreta. ¡MUY IMPORTANTE!
# Aquí guardarás tu SECRET_KEY, claves de API, etc.
local_settings.py
.env
secrets.json

# Carpetas de medios (subidas por usuarios) y estáticos (collectstatic)
/media/
/static/

### Entornos Virtuales ###
# Ignorar TODA la carpeta del entorno virtual. Es enorme y específica de tu máquina.
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

### IDEs y editores de código (PyCharm, VS Code, Vim) ###
# Configuraciones específicas de tu editor que no deben compartirse.
.idea/
.vscode/
*.swp
*.swo
.history/

*initial.py

### Sistemas Operativos (macOS, Linux, Windows) ###
# Archivos basura o de caché del sistema.
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*~